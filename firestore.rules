rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isOwner() {
      return request.auth != null
        && request.auth.uid == "REPLACE_WITH_YOUR_UID";
    }

    match /users/{uid} {
      allow read, write: if isOwner();

      match /{document=**} {
        allow read, write: if isOwner();
      }
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
