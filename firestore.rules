rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isOwner(uid) {
      return request.auth != null
        && request.auth.uid == uid
        && request.auth.uid == "REPLACE_WITH_YOUR_UID";
    }

    match /users/{uid} {
      allow read, write: if isOwner(uid);

      match /sharedInbox/{captureId} {
        allow read, write: if isOwner(uid);
      }

      match /{document=**} {
        allow read, write: if isOwner(uid);
      }
    }

    match /publicShares/{shareId} {
      allow get: if resource.data.visibility == "share-link"
        && resource.data.active == true
        && (!resource.data.keys().hasAny(["shareExpiresAt"]) || resource.data.shareExpiresAt == null || resource.data.shareExpiresAt > request.time);
      allow list: if false;
      allow create, update, delete: if request.auth != null && request.auth.uid == "REPLACE_WITH_YOUR_UID";
    }
    match /{document=**} {
      allow read, write: if false;
    }
  }
}